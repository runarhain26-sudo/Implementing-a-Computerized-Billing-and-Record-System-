    private void jButton2ActionPerformed(java.awt.event.ActionEvent evt) {                                         
       String username = usernamefield.getText().trim();
        String password = new String(passwordfield1.getPassword()).trim();

        // Database connection details
        String url = "jdbc:mysql://localhost:3306/dbregister"; // Your DB name
        String dbUser = "root";
        String dbPass = "";    

        try {
          
            Class.forName("com.mysql.cj.jdbc.Driver");

            Connection con = DriverManager.getConnection(url, dbUser, dbPass);

            System.out.println("Username entered: " + username);
            System.out.println("Password entered: " + password);

         
            String sql = "SELECT * FROM pipol_broadband WHERE BINARY name = ? AND BINARY password = ?";
            PreparedStatement pst = con.prepareStatement(sql);
            pst.setString(1, username);
            pst.setString(2, password);

            ResultSet rs = pst.executeQuery();

            if (rs.next()) {
                JOptionPane.showMessageDialog(this, "Login successful! Welcome " + username);
                this.dispose();
                
              
                registeremployee homeWindow = new registeremployee(username);
                homeWindow.setLocationRelativeTo(null);
                homeWindow.setVisible(true);
            } else {
                JOptionPane.showMessageDialog(this, "Invalid username or password");
            }

            con.close();
        } catch (Exception e) {
            e.printStackTrace();
            JOptionPane.showMessageDialog(this, "Login Error: " + e.getMessage());
        }                    
    }                                        

